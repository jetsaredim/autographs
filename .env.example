# Local development defaults for the Phase 1 proof-of-life app.
# Copy to `.env.local` or export values in your shell when needed.

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Autographs

# Runtime smoke defaults. Production exposes Caddy through Podman quadlets and
# keeps the Next.js app private on the dedicated Podman network.
AUTOGRAPHS_HTTP_PORT=8080
AUTOGRAPHS_APP_IMAGE=autographs-app:local

# OCI deployment coordinates used by local operator scripts and documentation.
# Real credentials and private keys must not be committed.
OCI_REGION=us-ashburn-1
OCI_HOME_REGION=us-ashburn-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..replace_me
OCI_TENANCY_OCID=ocid1.tenancy.oc1..replace_me
OCI_CLI_USER_OCID=ocid1.user.oc1..replace_me
OCI_FINGERPRINT=12:34:56:78:90:ab:cd:ef:12:34:56:78:90:ab:cd:ef
OCI_PRIVATE_KEY_PATH=~/.oci/autographs_api_key.pem

# Terraform runtime deploy inputs. Tenancy bootstrap inputs live in
# infra/terraform/tenancy/environments/prod/terraform.tfvars.example.
TF_VAR_project_name=autographs
TF_VAR_environment=prod
TF_VAR_name_prefix=autographs-prod
TF_VAR_compartment_ocid=ocid1.compartment.oc1..replace_me
TF_VAR_availability_domain=replace-with-ashburn-ad
TF_VAR_runtime_image_ocid=ocid1.image.oc1..replace_me
TF_VAR_runtime_ssh_public_keys='["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIreplace_me operator@laptop"]'
OCI_OBJECT_STORAGE_NAMESPACE=replace-with-your-object-storage-namespace
TF_VAR_create_autonomous_database=false
TF_VAR_autonomous_database_name=autographsdb
TF_VAR_autonomous_database_display_name=autographs-prod-adb
TF_VAR_autonomous_database_admin_password=replace-with-secure-adb-admin-password
TF_VAR_create_media_bucket=false
TF_VAR_media_bucket_namespace=replace-with-your-object-storage-namespace
TF_VAR_media_bucket_name=autographs-media-prod

# Remote deployment target. VM_PUBLIC_IP is normally copied from Terraform
# output `runtime_public_ip` after the OCI baseline is applied.
VM_PUBLIC_IP=203.0.113.10
DEPLOY_SSH_USER=opc
DEPLOY_PATH=/opt/autographs
GHCR_IMAGE_REPOSITORY=ghcr.io/jetsaredim/autographs/app

# Phase 2 Oracle Autonomous Database metadata store. Keep real passwords,
# wallet files, and connection material in `.env.local` or GitHub Secrets.
AUTOGRAPHS_DB_PROVIDER=oracle
ORACLE_DB_USER=ADMIN
ORACLE_DB_PASSWORD=replace-with-secure-password
ORACLE_DB_CONNECT_STRING="(description= (retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=adb.us-ashburn-1.oraclecloud.com))(connect_data=(service_name=replace_me_medium.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))"
ORACLE_DB_WALLET_DIR=
DATABASE_URL=

# Phase 2 private media bucket coordinates. The bucket remains private and
# images are served through the app, not public Object Storage URLs.
AUTOGRAPHS_MEDIA_STORAGE_PROVIDER=local
AUTOGRAPHS_LOCAL_MEDIA_ROOT=/tmp/autographs-media
AUTOGRAPHS_OPERATOR_API_TOKEN=replace-with-local-operator-token
OCI_MEDIA_BUCKET_NAME=autographs-media-prod
OCI_MEDIA_NAMESPACE=replace-with-your-object-storage-namespace

# Phase 5 private Rust controller and static publisher. Supply real secrets from
# local untracked env files or the runtime operator secret store.
AUTOGRAPHS_CONTROLLER_BIND_ADDR=0.0.0.0:8080
AUTOGRAPHS_PUBLIC_ORIGIN=https://autographs.example.test
AUTOGRAPHS_ADMIN_SECURE_COOKIES=false
AUTOGRAPHS_ADMIN_PASSWORD_HASH=replace-with-argon2-password-hash
# Local development only. Production uses AUTOGRAPHS_ADMIN_PASSWORD_HASH.
AUTOGRAPHS_ADMIN_PASSWORD=replace-with-local-development-password
AUTOGRAPHS_STATIC_RELEASE_ROOT=/tmp/autographs-static
AUTOGRAPHS_STATIC_CURRENT_LINK=/tmp/autographs-static/current
AUTOGRAPHS_STATIC_FAILED_CANDIDATE_RETAIN_COUNT=1
AUTOGRAPHS_PUBLISH_MODE=incremental
AUTOGRAPHS_CONTROLLER_MEDIA_STORAGE_PROVIDER=oci-instance-principal
OCI_AUTH_MODE=instance_principal
