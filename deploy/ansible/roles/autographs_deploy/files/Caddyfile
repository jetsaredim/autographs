:80, http://{$AUTOGRAPHS_DOMAIN} {
	redir https://{host}{uri} permanent
}

{$AUTOGRAPHS_DOMAIN} {
	encode zstd gzip

	@operator path /api/operator /api/operator/*
	respond @operator 404

	handle /admin/api/* {
		reverse_proxy autographs-controller:8080
	}

	handle /admin {
		redir /admin/ permanent
	}

	handle_path /admin/* {
		root * /srv/autographs/admin
		try_files {path} /index.html
		file_server
	}

	# Keep the current Next.js public runtime until the explicit Phase 5 cutover.
	reverse_proxy autographs-app:3000 {
		lb_try_duration 5s
		lb_policy first
	}
}

http://:8081 {
	root * /srv/autographs/static
	file_server
}
