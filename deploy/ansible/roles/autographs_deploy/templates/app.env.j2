AUTOGRAPHS_APP_IMAGE={{ autographs_app_image }}
AUTOGRAPHS_TOOLS_IMAGE={{ autographs_tools_image }}
AUTOGRAPHS_DOMAIN={{ autographs_deploy_domain }}
AUTOGRAPHS_HTTP_PORT={{ autographs_deploy_http_port }}
AUTOGRAPHS_HTTPS_PORT={{ autographs_deploy_https_port }}
AUTOGRAPHS_DB_PROVIDER=oracle
ORACLE_DB_USER={{ oracle_db_user | default('ADMIN') }}
ORACLE_DB_PASSWORD={{ lookup('env', 'ORACLE_DB_PASSWORD') | default('', true) }}
ORACLE_DB_CONNECT_STRING={{ oracle_db_connect_string | default('autographsdb_medium') }}
ORACLE_DB_WALLET_DIR=/opt/autographs/wallet
ORACLE_DB_WALLET_PASSWORD={{ lookup('env', 'ORACLE_DB_WALLET_PASSWORD') | default('', true) }}
AUTOGRAPHS_MEDIA_STORAGE_PROVIDER=oci
AUTOGRAPHS_OPERATOR_API_TOKEN={{ lookup('env', 'AUTOGRAPHS_OPERATOR_API_TOKEN') | default('', true) }}
OCI_REGION={{ oci_region | default('us-ashburn-1') }}
OCI_TENANCY_OCID={{ lookup('env', 'OCI_TENANCY_OCID') | default('', true) }}
OCI_CLI_USER_OCID={{ lookup('env', 'OCI_CLI_USER_OCID') | default('', true) }}
OCI_FINGERPRINT={{ lookup('env', 'OCI_FINGERPRINT') | default('', true) }}
OCI_PRIVATE_KEY_PATH=/opt/autographs/secrets/oci_api_key.pem
OCI_MEDIA_BUCKET_NAME={{ oci_media_bucket_name | default('autographs-media-prod') }}
OCI_MEDIA_NAMESPACE={{ oci_media_namespace | default(lookup('env', 'OCI_MEDIA_NAMESPACE') | default('', true), true) }}
