FROM rust:1.96-bookworm AS builder

WORKDIR /workspace

COPY controller/Cargo.toml controller/Cargo.lock ./
COPY controller/src ./src
COPY controller/static-public ./static-public

RUN cargo build --release --features production-persistence

FROM oraclelinux:9-slim

RUN microdnf install -y oracle-instantclient-release-23ai-el9 \
    && microdnf install -y ca-certificates oracle-instantclient-basic \
    && microdnf clean all

COPY --from=builder /workspace/target/release/autographs-controller /usr/local/bin/autographs-controller
COPY controller/static-admin /opt/autographs/static-admin

ENV TNS_ADMIN=/opt/autographs/wallet

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/autographs-controller"]
