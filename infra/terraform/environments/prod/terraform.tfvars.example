# Copy this file to infra/terraform/environments/prod/terraform.tfvars locally
# and replace every placeholder. Keep real secrets and private paths out of VCS.

project_name = "autographs"
environment  = "prod"
name_prefix  = "autographs-prod"

auth                = "APIKey"
config_file_profile = ""

tenancy_ocid     = "ocid1.tenancy.oc1..replace_me"
user_ocid        = "ocid1.user.oc1..replace_me"
fingerprint      = "12:34:56:78:90:ab:cd:ef:12:34:56:78:90:ab:cd:ef"
private_key_path = "~/.oci/autographs_api_key.pem"

# For local bootstrap with `oci session authenticate`, use:
# auth                = "SecurityToken"
# config_file_profile = "DEFAULT"
# Leave user_ocid, fingerprint, and private_key_path empty.

# home_region is where OCI IAM resources such as policies and compartments live.
# region is where the runtime network, VM, and state bucket live.
home_region = "us-ashburn-1"
region      = "us-ashburn-1"

# Use the tenancy OCID when attaching the project compartment directly under the
# tenancy root. Use another parent compartment OCID if you already organize OCI
# under a broader shared hierarchy.
parent_compartment_ocid = "ocid1.tenancy.oc1..replace_me"

create_compartment       = true
existing_compartment_ocid = ""
compartment_description  = "Autographs production resources"

owner_email         = "collector@example.com"
deploy_group_name   = "autographs-deployers"
operator_group_name = "autographs-operators"

create_state_bucket      = true
state_bucket_name        = "autographs-tf-state"
state_bucket_storage_tier = "Standard"
state_object_key         = "envs/prod/terraform.tfstate"

create_network           = true
vcn_cidr_block           = "10.42.0.0/16"
public_subnet_cidr_block = "10.42.10.0/24"
ssh_ingress_cidrs        = ["203.0.113.10/32"]
http_ingress_cidrs       = ["0.0.0.0/0"]
https_ingress_cidrs      = ["0.0.0.0/0"]

create_runtime_instance      = true
availability_domain          = "DcRr:US-ASHBURN-AD-3"
runtime_shape                = "VM.Standard.E2.1.Micro"
runtime_ocpus                = 1
runtime_memory_gbs           = 1
runtime_boot_volume_size_gbs = 50
runtime_image_ocid           = ""
oracle_linux_image_ocids = {
  "us-ashburn-1" = "ocid1.image.oc1.iad.replace_me"
}
runtime_ssh_public_keys = [
  "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIreplace_me operator@laptop"
]
assign_public_ip = true
