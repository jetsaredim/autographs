# Copy this file to infra/terraform/environments/prod/terraform.tfvars locally
# for runtime/app Terraform. Bootstrap tenancy resources first with
# infra/terraform/tenancy/environments/prod/terraform.tfvars.example.
# Keep real secrets and private paths out of VCS.

project_name = "autographs"
environment  = "prod"
name_prefix  = "autographs-prod"

auth                = "APIKey"
config_file_profile = ""

tenancy_ocid     = "ocid1.tenancy.oc1..replace_me"
user_ocid        = "ocid1.user.oc1..replace_me"
fingerprint      = "12:34:56:78:90:ab:cd:ef:12:34:56:78:90:ab:cd:ef"
private_key_path = "~/.oci/autographs_api_key.pem"

# For local bootstrap with `oci session authenticate`, use:
# auth                = "SecurityToken"
# config_file_profile = "DEFAULT"
# Leave user_ocid, fingerprint, and private_key_path empty.

region           = "us-ashburn-1"
owner_email      = "collector@example.com"
compartment_ocid = "ocid1.compartment.oc1..replace_me"

create_network           = true
vcn_cidr_block           = "10.42.0.0/16"
public_subnet_cidr_block = "10.42.10.0/24"
ssh_ingress_cidrs        = ["203.0.113.10/32"]
http_ingress_cidrs       = ["0.0.0.0/0"]
https_ingress_cidrs      = ["0.0.0.0/0"]

create_runtime_instance      = true
availability_domain          = "DcRr:US-ASHBURN-AD-3"
runtime_shape                = "VM.Standard.E2.1.Micro"
runtime_ocpus                = 1
runtime_memory_gbs           = 1
runtime_boot_volume_size_gbs = 50
runtime_image_ocid           = ""
oracle_linux_image_ocids = {
  "us-ashburn-1" = "ocid1.image.oc1.iad.replace_me"
}
runtime_ssh_public_keys = [
  "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIreplace_me operator@laptop"
]
runtime_deploy_user = "opc"
runtime_deploy_path = "/opt/autographs"
assign_public_ip = true

# Phase 2 data services. Keep create_autonomous_database false until the
# admin password is supplied through an untracked tfvars file or GitHub Secret.
create_autonomous_database                   = false
autonomous_database_name                     = "autographsdb"
autonomous_database_display_name             = "autographs-prod-adb"
autonomous_database_admin_password           = ""
autonomous_database_is_free_tier             = true
autonomous_database_is_mtls_connection_required = true
autonomous_database_db_workload              = "OLTP"
autonomous_database_license_model            = "LICENSE_INCLUDED"
autonomous_database_data_storage_size_in_tbs = 1

create_media_bucket     = false
media_bucket_namespace  = "replace-with-your-object-storage-namespace"
media_bucket_name       = "autographs-media-prod"
media_bucket_versioning = "Enabled"
