# GitHub Actions configuration contract for Phase 1.
# Populate these as repo-level GitHub Secrets or GitHub Variables as noted.
# Optional GitHub Environments may layer approvals on top, but the baseline
# workflow expects repo-level values.

## Repo-level GitHub Secrets

OCI_CLI_USER_OCID=ocid1.user.oc1..replace_me
OCI_TENANCY_OCID=ocid1.tenancy.oc1..replace_me
OCI_FINGERPRINT=12:34:56:78:90:ab:cd:ef:12:34:56:78:90:ab:cd:ef
# Stored as a GitHub Secret. Deploy writes it to a protected VM file and
# passes OCI_PRIVATE_KEY_PATH to the app container; do not put this in Compose.
OCI_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----..."

DEPLOY_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----..."
ADB_ADMIN_PASSWORD="replace-with-secure-adb-admin-password"
ORACLE_DB_PASSWORD="replace-with-runtime-db-password"
ORACLE_DB_WALLET_PASSWORD="replace-with-wallet-password"
ORACLE_DB_WALLET_ZIP_BASE64="replace-with-base64-encoded-wallet-zip"
AUTOGRAPHS_OPERATOR_API_TOKEN="replace-with-random-operator-token"

## Repo-level GitHub Variables

OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..replace_me
OCI_AVAILABILITY_DOMAIN=replace-with-ashburn-ad
OCI_RUNTIME_IMAGE_OCID=ocid1.image.oc1..replace_me
OCI_RUNTIME_SHAPE=VM.Standard.E2.1.Micro
OCI_RUNTIME_OCPUS=1
OCI_RUNTIME_MEMORY_GBS=1
OCI_RUNTIME_SSH_PUBLIC_KEYS='["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIreplace_me github-actions@autographs"]'
OCI_OBJECT_STORAGE_NAMESPACE=replace-with-your-object-storage-namespace
OCI_CREATE_AUTONOMOUS_DATABASE=false
OCI_AUTONOMOUS_DATABASE_NAME=autographsdb
OCI_AUTONOMOUS_DATABASE_DISPLAY_NAME=autographs-prod-adb
OCI_CREATE_MEDIA_BUCKET=false
OCI_MEDIA_BUCKET_NAME=autographs-media-prod
OCI_MEDIA_NAMESPACE=replace-with-your-object-storage-namespace
ORACLE_DB_USER=ADMIN
ORACLE_DB_CONNECT_STRING="(description= (retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=adb.us-ashburn-1.oraclecloud.com))(connect_data=(service_name=replace_me_medium.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))"
ORACLE_DB_WALLET_DIR=
AUTOGRAPHS_MEDIA_STORAGE_PROVIDER=oci

VM_PUBLIC_IP=203.0.113.10
DEPLOY_SSH_USER=opc
DEPLOY_PATH=/opt/autographs
AUTOGRAPHS_DOMAIN=autographs.jetsaredim.net
GHCR_IMAGE_REPOSITORY=ghcr.io/jetsaredim/autographs/app
